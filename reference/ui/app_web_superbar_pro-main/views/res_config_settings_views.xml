<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='integration']" position="after">
                <block title="User Interface(Super Search Options)" name="superbar">
                    <div class="row mt16 o_settings_container" name="app_ui_superbar">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="app_default_superbar_and_search"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="app_default_superbar_and_search" class="oe_inline"/>
                            </div>
                            <div class="text-muted">
                                Press 'shift' key to Use And filter for same field. Search result must fix all keyword input.
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="app_default_superbar_lazy_search"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="app_default_superbar_lazy_search" class="oe_inline"/>
                            </div>
                            <div class="text-muted">
                                Set up all filter first, then click search to get filter data.
                            </div>
                        </div>
                    </div>

                </block>
            </xpath>
        </field>
    </record>

</odoo>