<odoo>
    <data>
        <!--menu invoicing-->
        <record id="account.menu_finance" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>
        <!--menu Maintenance -->
        <record id="maintenance.menu_maintenance_title" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>
        <!--menu Inventory-->
        <record id="stock.menu_stock_root" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>
        <!--menu Quality-->
        <!-- <record id="quality_control.menu_quality_root" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record> -->

        <record id="change_password_wizard_view_inherit" model="ir.ui.view">
            <field name="name">Change Password Inherit</field>
            <field name="model">change.password.wizard</field>
            <field name="inherit_id" ref="base.change_password_wizard_view"/>
            <field name="arch" type="xml">
                <!-- Example: Add a note above the form -->
                <xpath expr="//field[@name='user_ids']" position="replace">
                    <field name="user_ids">
                        <tree create="0" editable="bottom">
                            <field name="user_id" column_invisible="1" force_save="1"/>
                            <field name="user_login"/>
                            <field name="new_passwd"/>
                        </tree>
                    </field>
                </xpath>
            </field>
        </record>
        <record model="ir.actions.server" id="action_assign_combination_groups">
            <field name="name">Update User Type and Hide Menu</field>
            <field name="model_id" ref="autonsi_access_right_management.model_res_users"/>
            <field name="binding_model_id" ref="autonsi_access_right_management.model_res_users"/>
            <field name="state">code</field>
            <field name="binding_view_types">list,form</field>
            <field name="code">
                action = records.assign_hide_menu()
            </field>
            <field name="groups_id" eval="[(4, ref('base.group_no_one'))]"/>
        </record>

        <record model="ir.actions.server" id="action_action_apply_menu_default">
            <field name="name">Update Menu Default Sidebar</field>
            <field name="model_id" ref="autonsi_access_right_management.model_res_users"/>
            <field name="binding_model_id" ref="autonsi_access_right_management.model_res_users"/>
            <field name="state">code</field>
            <field name="binding_view_types">list,form</field>
            <field name="code">
                action = records.action_apply_menu_when_create()
            </field>
            <field name="groups_id" eval="[(4, ref('base.group_no_one'))]"/>
        </record>


        <!-- Menu Item -->
        <menuitem id="menu_user_management_root" name="User Management" sequence="110"
                  web_icon="autonsi_access_right_management,static/description/icon.png"/>


        <!-- Tree View -->
        <record id="view_user_tree" model="ir.ui.view">
            <field name="name">user.tree</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <tree string="Users">
                    <field name="login"/>
                    <!--                    <field name="team_id"/>-->
                    <field name="name"/>
                    <field name="state" widget="badge" decoration-info="state == 'new'"
                           decoration-success="state == 'active'"/>
                    <button name="action_open_change_password" type="object" string="Change Password"
                            class="btn-primary"/>
                    <field name="email" invisible="1"/>
                    <field name="phone"/>
                    <field name="mobile"/>
                    <field name="position"/>
                    <field name="discuss_rights"/>
                    <field name="calendar_rights"/>
                    <field name="document_rights"/>
                    <field name="standard_rights"/>
                    <field name="sales_rights"/>
                    <field name="purchase_rights"/>
                    <field name="m_wms_rights"/>
                    <field name="wip_wms_rights"/>
                    <field name="fg_wms_rights"/>
                    <field name="mps_rights"/>
                    <field name="pms_rights"/>
                    <field name="cmms_rights"/>
                    <field name="mms_rights"/>
                    <field name="qms_rights"/>
                    <field name="user_mng_rights"/>
                    <field name="create_date" string="Reg Date"/>
                    <field name="write_date" string="Update Date"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_user_form" model="ir.ui.view">
            <field name="name">user.form</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <form string="User">
                    <sheet>
                        <group>
                            <group>
                                <field name="login" string="Email Address"/>
                                <!--                                <field name="team_id" options="{'no_open': True, 'no_create': True}"/>-->
                                <field name="name" required="1"/>
                                <field name="state" widget="badge" decoration-info="state == 'new'"
                                       decoration-success="state == 'active'"/>
                                <field name="email" invisible="1"/>
                                <field name="phone"/>
                                <field name="mobile"/>
                                <field name="position"/>
                                <field name="x_user_category"/>
                            </group>
                            <group>
                                <field name="discuss_rights"/>
                                <field name="calendar_rights"/>
                                <field name="document_rights"/>
                                <field name="standard_rights"/>
                                <field name="sales_rights"/>
                                <field name="purchase_rights"/>
                                <field name="m_wms_rights"/>
                                <field name="wip_wms_rights"/>
                                <field name="fg_wms_rights"/>
                                <field name="mps_rights"/>
                                <field name="pms_rights"/>
                                <field name="cmms_rights"/>
                                <field name="mms_rights"/>
                                <field name="qms_rights"/>
                                <field name="user_mng_rights"/>
                                <field name="mms_shop_floor_rights"/>
                                <field name="pms_shop_floor_rights"/>
                                <field name="create_date" string="Reg Date"/>
                                <field name="write_date" string="Update Date"/>
                                <field name="groups_id" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="hide_menu" string="Hide Menu">
                                <field name="hide_menu_ids"
                                       domain="['|', ('parent_id', '=', False), ('action', '!=', False)]">
                                    <tree editable="bottom">
                                        <field name="complete_name"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="user_groups_view" model="ir.ui.view">
            <field name="name">res.users.groups</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='access_rights']//group" position="before">
                    <group>
                        <field name="x_user_category"/>
                    </group>
                </xpath>

            </field>
        </record>

        <!-- Action -->
        <record id="action_user_management" model="ir.actions.act_window">
            <field name="name">Users</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{"is_show_form": false, "show_first": false, 'default_sy_user_type': 'sy'}</field>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'tree', 'view_id': ref('view_user_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('view_user_form')})]"/>
            <field name="domain">[]</field>
        </record>


        <!-- Link Menu Item to Action -->
        <menuitem id="menu_user_management_users" name="Users" parent="menu_user_management_root"
                  action="action_user_management" sequence="10"/>
    </data>
</odoo>