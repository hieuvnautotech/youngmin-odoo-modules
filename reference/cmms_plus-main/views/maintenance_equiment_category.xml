<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
        <record model="ir.ui.view" id="cmms_plus_equipment_category_view_form_inherit">
                    <field name="name">autonsi_cmms_equipment_category_view_form_inherit</field>
                    <field name="model">maintenance.equipment.category</field>
                    <field name="inherit_id" ref="maintenance.hr_equipment_category_view_form"/>
                    <field name="arch" type="xml">
                        <xpath expr="//field[@name='technician_user_id']" position="before">
                        <field name="type" />
                        </xpath>
                    </field>
        </record>

        <record id="action_cmms_plus_equipment_category" model="ir.actions.act_window">
                <field name="name">Equipment Category</field>
                <field name="res_model">maintenance.equipment.category</field>
                <field name="view_mode">tree,form</field>
                <field name="domain">[]</field>
                
                <field name="view_ids" eval="[
                (5, 0, 0), (0, 0, {'view_mode': 'tree', 'view_id': ref('maintenance.hr_equipment_category_view_tree')})]" />
        </record>


</odoo>