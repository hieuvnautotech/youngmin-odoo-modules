    <!-- Action mở product.product theo kanban -->
    <record id="action_product_product_kanban_custom" model="ir.actions.act_window">
        <field name="name">Products (Kanban)</field>
        <field name="res_model">product.product</field>
        <field name="domain">['|',('is_jig','=',True),('is_machine','=',True)]</field> 
        <field name="context">{'cmms_quick_form':True}</field> 

         <field name="search_view_id" ref="cmms_plus_product_product_search_view"/>
      
         <field name="view_mode">kanban,tree,form</field>
         <field name="view_ids" eval="[
          
            (5, 0, 0), (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_product_product_kanban_custom')}) ,
             (5, 0, 0), (0, 0, {'view_mode': 'tree', 'view_id': ref('cmms_plus_equipment_view_tree')}) ,
             (5, 0, 0), (0, 0, {'view_mode': 'form', 'view_id': ref('cmms_plus_equipment_view_form')})

            ]" />


    </record>


</odoo>
