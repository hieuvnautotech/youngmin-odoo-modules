<odoo>
    <data>
        <record id="view_mes_qc_form_tree" model="ir.ui.view">
            <field name="name">mes.qc_form.tree.inherit</field>
            <field name="model">mes.qc_form</field>
            <field name="inherit_id" ref="autonsi_qms.view_mes_qc_form_tree" />
            <field name="arch" type="xml">
                <field name="used" position="after">
                    <button name="preview_form" type="object" string="Preview" class="oe_highlight" />
                </field>
            </field>
        </record>

        <record id="view_mes_qc_form_form" model="ir.ui.view">
            <field name="name">mes.qc_form.form.inherit</field>
            <field name="model">mes.qc_form</field>
            <field name="inherit_id" ref="autonsi_qms.view_mes_qc_form_form" />
            <field name="arch" type="xml">
                <header position="inside">
                    <button name="preview_form" type="object" string="Preview Form" class="oe_highlight" />
                </header>
            </field>
        </record>
    </data>
</odoo>