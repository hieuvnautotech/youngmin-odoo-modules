	<!--	Form View -->
	<record id="view_mes_qc_form_history_form" model="ir.ui.view">
		<field name="name">mes.qc_form.history.form</field>
		<field name="model">mes.qc_form.history</field>
		<field name="arch" type="xml">
			<form create="0" edit="0" delete="0">
                <header>
                    <button name="action_open_iqc_form_history" type="object" string="Preview" class="oe_highlight" />
                </header>
				<group>
					<group>
						<field name="type_material"/>
                        <field name="name" string="Title"/>
                        <field name="lot_id" />
                        <field name="overall_result"/>
					</group>
					<group>
						<field name="staff_name"/>
                        <field name="check_date"/>
                        <field name="unit"/>
					</group>
				</group>
				<notebook>
					<page name="qc_list" string="QC List">
						<field name="question_ids">
							<tree editable="bottom">
<!--								<field name="mes_qc_form_question_id" widget="many2one_tags"/>-->
								<field name="X1"/>
								<field name="X2"/>
								<field name="X3"/>
								<field name="X4"/>
								<field name="X5"/>
							</tree>
						</field>
					</page>
				</notebook>
			</form>
		</field>
	</record>

	<record id="mes_qc_form_history_search_view" model="ir.ui.view">
		<field name="name">mes.qc_form.history.search</field>
		<field name="model">mes.qc_form.history</field>
		<field name="arch" type="xml">
			<search string="QC History">

				<!-- Search fields -->
				<field name="name"/>
				<field name="mes_qc_form_id"/>
				<field name="lot_id"/>
				<field name="product_id"/>
				<field name="material_code"/>
				<field name="material_name"/>
				<field name="staff_id"/>

				<!-- Filters -->
				<filter string="IQC" name="filter_iqc"
					domain="[('form_type', '=', 'iqc')]"/>
				<filter string="PQC" name="filter_pqc"
					domain="[('form_type', '=', 'pqc')]"/>
				<filter string="OQC" name="filter_oqc"
					domain="[('form_type', '=', 'oqc')]"/>

				<separator/>

				<filter string="Holding" name="filter_hold"
					domain="[('status', '=', 'hold')]"/>
				<filter string="Release" name="filter_release"
					domain="[('status', '=', 'release')]"/>

				<separator/>

				<filter string="Today" name="filter_today"
					domain="[('check_date', '>=', context_today())]"/>

				<!-- Group By -->
				<group expand="0" string="Group By">
					<filter string="Form Type" name="group_form_type"
						context="{'group_by': 'form_type'}"/>
					<filter string="Status" name="group_status"
						context="{'group_by': 'status'}"/>
					<filter string="Item Group" name="group_item_group"
						context="{'group_by': 'item_group'}"/>
					<filter string="Product" name="group_product"
						context="{'group_by': 'product_id'}"/>
					<filter string="Lot" name="group_lot"
						context="{'group_by': 'lot_id'}"/>
					<filter string="Check Date" name="group_check_date"
						context="{'group_by': 'check_date'}"/>
				</group>

			</search>
		</field>
	</record>

    	<!--	Action -->
	<record id="action_mes_qc_form_history_iqc" model="ir.actions.act_window">
		<field name="name">IQC History</field>
		<field name="type">ir.actions.act_window</field>
		<field name="res_model">mes.qc_form.history</field>
		<field name="view_mode">tree,form</field>
		<field name="view_id" ref="mes_qc_form_history_iqc_tree_view"/>
        <field name="domain">[('form_type','=','iqc'), ('is_history','=',True)]</field>
		<field name="help" type="html">
			<p class="o_view_nocontent_smiling_face">
				Create your first Result!
			</p>
		</field>
	</record>

