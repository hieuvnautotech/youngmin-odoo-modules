<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Test Parent Form View -->
    <record id="view_test_parent_form" model="ir.ui.view">
        <field name="name">test.parent.form</field>
        <field name="model">test.parent</field>
        <field name="arch" type="xml">
            <form string="Test Parent">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>

                    <notebook>
                        <!-- Tab 1: One2Many with enhanced widget -->
                        <page string="Lines (Enhanced)">
                            <field name="line_ids" widget="x2many_field_enhanced" context="{'list_groupbys':['name','product_id']}">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="product_id"/>
                                    <field name="category_id"/>
                                    <field name="quantity"/>
                                    <field name="price"/>
                                    <field name="amount"/>
                                    <field name="state"/>
                                    <field name="date"/>
                                    <field name="is_active"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Tab 2: One2Many with standard widget (để so sánh) -->
                        <page string="Lines (Standard)">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="price"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Tab 3: Many2Many with enhanced widget -->
                        <page string="Tags (Enhanced)">
                            <field name="tag_ids" widget="x2many_field_enhanced">
                                <tree>
                                    <field name="name"/>
                                    <field name="color" widget="color_picker"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Test Parent Tree View -->
    <record id="view_test_parent_tree" model="ir.ui.view">
        <field name="name">test.parent.tree</field>
        <field name="model">test.parent</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <!-- Test Parent Action -->
    <record id="action_test_parent" model="ir.actions.act_window">
        <field name="name">Test Parent</field>
        <field name="res_model">test.parent</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_test_parent_root" name="Test X2Many Enhanced" sequence="100"/>

    <menuitem id="menu_test_parent" name="Test Parent" parent="menu_test_parent_root" action="action_test_parent" sequence="10"/>

    <!-- Category Views -->
    <record id="view_test_category_tree" model="ir.ui.view">
        <field name="name">test.category.tree</field>
        <field name="model">test.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <record id="view_test_category_form" model="ir.ui.view">
        <field name="name">test.category.form</field>
        <field name="model">test.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_test_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">test.category</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_test_category" name="Categories" parent="menu_test_parent_root" action="action_test_category" sequence="20"/>

    <!-- Tag Views -->
    <record id="view_test_tag_tree" model="ir.ui.view">
        <field name="name">test.tag.tree</field>
        <field name="model">test.tag</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </tree>
        </field>
    </record>

    <record id="view_test_tag_form" model="ir.ui.view">
        <field name="name">test.tag.form</field>
        <field name="model">test.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_test_tag" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">test.tag</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- <menuitem id="menu_test_tag" name="Tags" parent="menu_test_parent_root" action="action_test_tag" sequence="30"/> -->

</odoo>