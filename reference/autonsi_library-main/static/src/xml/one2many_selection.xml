<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="One2ManySelectionListRenderer_no" t-inherit-mode="primary" t-inherit="web.ListRenderer">
        <xpath expr="//table/thead/tr/th" position="before">
            <th class="o_list_record_selector o_list_controller align-middle pe-1 cursor-pointer" tabindex="-1">
                <div class="o-checkbox form-check d-flex m-0">
                    <input type="checkbox" t-att-checked="one2ManySelectAll" class="form-check-input" id="checkbox-comp-1" registed="true" t-on-change="one2ManyToggleSelection"/>
                    <label class="form-check-label" for="checkbox-comp-1"></label>
                </div>
            </th>
            <th class="o_list_record_selector o_list_controller align-middle pe-1 cursor-pointer no-col" tabindex="-1">
                <div class="o-checkbox form-check d-flex m-0">
                    <label class="form-check-label" for="checkbox-comp-1">No.</label>
                </div>
            </th>
        </xpath>
        <xpath expr="//tfoot/tr/t" position="before">
            <t t-foreach="td_footer_num" t-as="td" t-key="td">
                <td/>
            </t>
        </xpath>
    </t>
    <t t-name="One2ManySelectionListRendererRecordRow_no" t-inherit-mode="primary" t-inherit="web.ListRenderer.RecordRow">
        <xpath expr="//tr/td" position="before">
            <th class="o_list_record_selector o_list_controller align-middle pe-1 cursor-pointer" tabindex="-1">
                <div class="o-checkbox form-check d-flex m-0">
                    <input type="checkbox" class="form-check-input" t-att-id="props.id or id" registed="true" t-att-checked="record.selected" t-on-change="() => this.one2ManyToggleRecordSelection(record)"/>
                    <label class="form-check-label" t-att-for="props.id or id"></label>
                </div>
            </th>
            <th class="o_list_record_selector o_list_controller align-middle pe-1 cursor-pointer" tabindex="-1">
                <div class="o-checkbox form-check d-flex m-0">
                    <label class="form-check-label" t-att-for="props.id or id" t-out="record_index + 1"></label>
                </div>
            </th>
        </xpath>
    </t>
</templates>