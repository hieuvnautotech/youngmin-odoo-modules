<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="one2many_search.One2ManySearch" t-inherit-mode="primary" t-inherit="web.X2ManyField">
        <xpath expr="//div[@class='o_x2m_control_panel d-empty-none mb-4']" position="before">
            <div class="one2many_search_container">
                <div class="oe_search_value o_cp_searchview d-flex input-group">
                    <div class="o_searchview form-control d-print-contents d-flex align-items-center py-1">
                        <i class="o_searchview_icon d-print-none oi oi-search me-2" role="img" aria-label="Search..." title="Search..."></i>
                        <div class="o_searchview_input_container d-flex flex-grow-1 flex-wrap gap-1">
                            <input type="text" class="o_searchview_input o_input d-print-none flex-grow-1 w-auto border-0" placeholder="Search..." t-on-keyup="onKeyUp" />
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
        <xpath expr="//div[@t-att-class='className']" position="attributes">
            <attribute name="t-ref">rootOne2manySearch</attribute>
        </xpath>
    </t>

    <t t-name="NoListRenderer" t-inherit-mode="primary" t-inherit="web.ListRenderer">
        <xpath expr="//table/thead/tr/th" position="after">
            <th class="o_list_record_selector o_list_controller align-middle pe-1 cursor-pointer no-col" tabindex="-1">
                <div class="o-checkbox form-check d-flex m-0">
                    <label class="form-check-label" for="checkbox-comp-1">No.</label>
                </div>
            </th>
        </xpath>

        <xpath expr="//tfoot/tr/t" position="before">
            <t t-foreach="td_footer_num" t-as="td" t-key="td">
                <td/>
            </t>
        </xpath>

    </t>
    <t t-name="NoListRendererRecordRow" t-inherit-mode="primary" t-inherit="web.ListRenderer.RecordRow">
        <xpath expr="//tr/td" position="after">
            <th class="o_list_record_selector o_list_controller align-middle pe-1 cursor-pointer" tabindex="-1">
                <div class="o-checkbox form-check d-flex m-0">
                    <label class="form-check-label" t-att-for="props.id or id" t-out="record_index + 1"></label>
                </div>
            </th>
        </xpath>
    </t>
</templates>