<?xml version="1.0" encoding="UTF-8"?>
<templates>
	<t t-inherit="web.SearchBar.Input" t-inherit-mode="extension">
		<xpath expr="//input" position="after">
			<button t-if="show_scan_button" type="button"
			        class="btn btn-sm btn-secondary o_list_button_scan_barcode me-2"
			        t-on-click="onScanQRClick"
			        title="Scan Barcode">
				<i class="fa fa-camera"/>
			</button>
			<!-- Video container -->
			<div id="scan-video-container"
			     style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1050; background-color: rgba(0,0,0,0.9);">
				<video id="scan-video" style="width: 100%; height: 100%; object-fit: cover;"/>
				<button type="button"
				        class="btn btn-light"
				        style="position: absolute; top: 10px; right: 10px; z-index: 1060;"
				        t-on-click="stopQRScanner">
					✖
				</button>
			</div>
		</xpath>
	</t>
</templates>