<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web.Many2OneQRScanField" owl="1">
        <div class="o_field_many2one_qr_scan d-flex align-items-center gap-1 w-100">
            <!-- Sử dụng lại template gốc của Many2OneField -->
            <div class="flex-grow-1">
                <t t-call="web.Many2OneField"/>
            </div>
            <!-- Nút scan QR -->
            <button type="button" class="btn btn-sm btn-secondary o_list_button_scan_barcode me-2" t-on-click="onScanQRClick" title="Scan Barcode">
                <i class="fa fa-camera"/>
            </button>
            <!-- Video container -->
            <div id="scan-video-container" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1050; background-color: rgba(0,0,0,0.9);">
                <video id="scan-video" style="width: 100%; height: 100%; object-fit: cover;"/>
                <button type="button" class="btn btn-light" style="position: absolute; top: 10px; right: 10px; z-index: 1060;" t-on-click="stopQRScanner">
					✖
                </button>
            </div>
        </div>
    </t>
</templates>
