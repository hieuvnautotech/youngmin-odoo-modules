<odoo>
    <record id="view_standard_process_line_tree" model="ir.ui.view">
        <field name="name">standard.process.line.tree</field>
        <field name="model">standard.process.line</field>
        <field name="arch" type="xml">
            <tree string="Process Lines" default_order="process_id">
                <field name="number_of_lines" />
                <field name="name" />
                <field name="process_id"/>
                <field name="remark"/>
            </tree>
        </field>
    </record>

    <record id="view_standard_process_line_form" model="ir.ui.view">
        <field name="name">standard.process.line.form</field>
        <field name="model">standard.process.line</field>
        <field name="arch" type="xml">
            <form string="Process Line">
                <sheet>
                    <group>
                        <field name="number_of_lines" />
                        <field name="process_id" options="{'no_create': True}" />
                        <field name="location_id" options="{'no_create': True}" />
                        <field name="name"/>
                        <field name="remark"/>
                        <field name="location_ids" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_standard_process_line" model="ir.actions.act_window">
        <field name="name">Lines</field>
        <field name="res_model">standard.process.line</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

</odoo>
