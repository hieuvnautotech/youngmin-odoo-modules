<odoo>
    <record id="autonsi_standard_product_tree" model="ir.ui.view">
        <field name="name">Material List</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <tree>
                <field name="priority" widget="priority" optional="show" nolabel="1"/>
                <field name="name"/>
                <field name="image_128" widget="image" class="standard-product-tree-image" options="{'image_preview': 'image_128'}" string="Image"/>
                <field name="product_model_id" string="Model"/>
                <field name="file" string="File" widget="file"/>
                <field name="remark" string="Remark"/>
            </tree>
        </field>
    </record>

    <record model="ir.ui.view" id="autonsi_standard_product_product_tree_inherit">
        <field name="name">product.product.tree.inherit</field>
        <field name="model">product.product</field>
        <field name="type">tree</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <field name="default_code" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="lst_price" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="virtual_available" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
        </field>
    </record>

    <record model="ir.ui.view" id="autonsi_standard_product_template_tree_inherit">
        <field name="name">product.template.tree.inherit</field>
        <field name="model">product.template</field>
        <field name="type">tree</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="default_code" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="list_price" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="standard_price" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="detailed_type" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
        </field>
    </record>

    <record model="ir.ui.view" id="autonsi_standard_product_product_form_inherit">
        <field name="name">product.product.form.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view" />
        <field name="arch" type="xml">
            <field name="description" position="attributes">
                <attribute name="placeholder"></attribute>
            </field>
            <field name="barcode" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <xpath expr="//div[hasclass('oe_title')]//label" position="replace">
                <label for="name" string="Name"/>
            </xpath>
            <!-- <xpath expr="//div[hasclass('oe_chatter')]" position="replace">
                <div style="display: none;"></div>
            </xpath> -->
            <xpath expr="//field[@name='uom_po_id']" position="after">
                <field name="product_type" readonly="1" force_save="1"/>
                <field name="product_sub_type" readonly="1" force_save="1"/>
            </xpath>
        </field>
    </record>

    <record id="autonsi_standard_product_action" model="ir.actions.act_window">
        <field name="name">Product</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="autonsi_standard_product_tree"/>
        <field name="domain">[('product_type', '=','fg product'), ('product_sub_type', '=', 'manual')]</field>
        <field name="context">{'default_product_type': 'fg product'}</field>
    </record>
</odoo>