<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree(list) View -->
    <record id="autonsi_standard_model_tree" model="ir.ui.view">
        <field name="name">Model List</field>
        <field name="model">standard.model</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
                <field name="remark"/>
                <field name="create_uid"/>
                <field name="create_date"/>
                <field name="write_uid"/>
                <field name="write_date"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="autonsi_standard_model_form" model="ir.ui.view">
        <field name="name">Model Form</field>
        <field name="model">standard.model</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <sheet>
                    <group>
                        <field name="name" required="1"/>
                        <field name="code"/>
                        <field name="description"/>
                        <field name="remark"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id='autonsi_standard_model_action' model='ir.actions.act_window'>
        <field name="name">Model</field>
        <field name="res_model">standard.model</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
