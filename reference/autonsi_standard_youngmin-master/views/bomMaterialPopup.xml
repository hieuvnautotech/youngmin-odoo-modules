<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bom_material_popup_base_form" model="ir.ui.view">
            <field name="name">custom.popup.form</field>
            <field name="model">mrp.bom.process</field>
            <field name="arch" type="xml">
                <form string="Custom Popup" readonly="1">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" string="Process Code" readonly="1"/>
                            </group>
                            <group>
                                <field name="level" readonly="1"/>
                                <field name="state" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Item">
                                <field name="material_ids" readonly="state=='confirmed'">
                                    <tree editable="bottom">
                                        <field name="name" string="Material" options="{'no_create': True}"/>
                                        <field name="quantity"/>
                                        <field name="unit" string="Unit" options="{'no_create': True}" readonly="1" force_save="1"/>
                                        <field name="loss_percent" widget="percentage"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_bom_material_popup_form" model="ir.ui.view">
            <field name="name">custom.popup.form</field>
            <field name="model">mrp.bom.process</field>
            <field name="priority" eval="100"/>
            <field name="arch" type="xml">
                <form string="Custom Popup" readonly="1">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" string="Process Code" readonly="1"/>
                            </group>
                            <group>
                                <field name="level" readonly="1"/>
                                <field name="state" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Item">
                                <field name="material_ids" readonly="state=='confirmed'">
                                    <tree editable="bottom">
                                        <field name="product_type" />
                                        <field name="name" string="Product Code" options="{'no_create': True}"/>
                                        <field name="product_name" string="Product Name"/>
                                        <field name="product_spec" string="Spec"/>
                                        <field name="quantity"/>
                                        <field name="loss_percent" widget="percentage"/>
                                        <field name="required_qty"/>
                                        <field name="unit" string="UoM" options="{'no_create': True}" readonly="1" force_save="1"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                        <footer>
                            <button string="Save" type="object" special="save" class="btn-primary"/>
                            <button string="Close" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
