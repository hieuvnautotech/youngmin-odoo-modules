<odoo>
    <data noupdate="1">
        <record id="seq_partner_code" model="ir.sequence">
            <field name="name">Partner Code</field>
            <field name="code">res.partner.code</field>
            <!--        <field name="prefix">C</field>-->
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_project_code" model="ir.sequence">
            <field name="name">Project Code</field>
            <field name="code">standard.project.code</field>
            <!--        <field name="prefix">C</field>-->
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_palet_no" model="ir.sequence">
            <field name="name">Pallet No</field>
            <field name="code">standard.pallet.pallet_no</field>
            <field name="prefix">P-</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_hr_employee" model="ir.sequence">
            <field name="name">Employee</field>
            <field name="code">hr.employee.staff_code</field>
<!--            <field name="prefix">P-</field>-->
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>


        <record id="product_category_fg" model="product.category">
            <field name="name">Product</field>
        </record>
        <record id="product_category_swh" model="product.category">
            <field name="name">SW.H</field>
            <field name="parent_id" ref="product_category_fg"/>
        </record>
        <record id="product_category_arh" model="product.category">
            <field name="name">AR.H</field>
            <field name="parent_id" ref="product_category_fg"/>
        </record>
        <record id="product_category_hm" model="product.category">
            <field name="name">S.H</field>
            <field name="parent_id" ref="product_category_fg"/>
        </record>

        <record id="product_category_material" model="product.category">
            <field name="name">Material</field>
        </record>


        





    </data>
        <record id="product.cat_expense" model="product.category">
            <field name="active">False</field>
        </record>
        
        <record id="product.product_category_1" model="product.category">
            <field name="active">False</field>
        </record>
</odoo>
