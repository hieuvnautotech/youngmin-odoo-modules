<odoo>
    <record id="module_category_standard_information" model="ir.module.category">
        <field name="name">Standard Information</field>
        <field name="description">Manage standard master data.</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_standard_user" model="res.groups">
        <field name="name">Standard User</field>
        <field name="category_id" ref="autonsi_standard_youngmin.module_category_standard_information"/>
    </record>

    <record id="group_standard_manager" model="res.groups">
        <field name="name">Standard Manager</field>
        <field name="category_id" ref="autonsi_standard_youngmin.module_category_standard_information"/>
        <field name="implied_ids" eval="[(4, ref('autonsi_standard_youngmin.group_standard_user'))]"/>
    </record>
</odoo>
