<odoo>
    <record id="view_standard_project_tree" model="ir.ui.view">
        <field name="name">standard.project.tree</field>
        <field name="model">standard.project</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="alias"/>
                <field name="project_start"/>
                <field name="project_end"/>
                <field name="project_period"/>
                <field name="project_status"/>
                <field name="development_status"/>
            </tree>
        </field>
    </record>

    <record id="view_standard_project_search" model="ir.ui.view">
        <field name="name">standard.project.search</field>
        <field name="model">standard.project</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="alias"/>
                <filter string="Draft" name="project_status_draft" domain="[('project_status', '=', 'draft')]"/>
                <filter string="Active" name="project_status_active" domain="[('project_status', '=', 'active')]"/>
                <filter string="Closed" name="project_status_closed" domain="[('project_status', '=', 'closed')]"/>
                <filter string="Developing" name="development_status_developing" domain="[('development_status', '=', 'developing')]"/>
                <filter string="Released" name="development_status_released" domain="[('development_status', '=', 'released')]"/>
                <filter string="Discontinued" name="development_status_discontinued" domain="[('development_status', '=', 'discontinued')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_project_status" context="{'group_by': 'project_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_standard_project_form" model="ir.ui.view">
        <field name="name">standard.project.form</field>
        <field name="model">standard.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Project Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="alias"/>
                            <field name="project_start"/>
                            <field name="project_end"/>
                            <field name="project_period"/>
                            <field name="project_status"/>
                        </group>
                        <group>
                            <field name="developer_charger"/>
                            <field name="development_status"/>
                            <field name="check_drawing_consistency"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Remark">
                            <field name="remark"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_standard_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">standard.project</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_standard_project_search"/>
    </record>
</odoo>
