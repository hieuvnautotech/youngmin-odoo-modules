<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_standard_common_tree" model="ir.ui.view">
        <field name="name">standard.common.tree</field>
        <field name="model">standard.common</field>
        <field name="arch" type="xml">
            <tree string="Commons">
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_standard_common_form" model="ir.ui.view">
        <field name="name">standard.common.form</field>
        <field name="model">standard.common</field>
        <field name="arch" type="xml">
            <form string="Common">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="detail_ids">
                            <tree editable="bottom">
                                <field name="sequence"/>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="active"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_standard_common_search" model="ir.ui.view">
        <field name="name">standard.common.search</field>
        <field name="model">standard.common</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
            </search>
        </field>
    </record>
</odoo>
