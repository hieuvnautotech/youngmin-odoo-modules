<odoo>
    <record id="view_standard_common_tree" model="ir.ui.view">
        <field name="name">standard.common.tree</field>
        <field name="model">standard.common</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_standard_common_form" model="ir.ui.view">
        <field name="name">standard.common.form</field>
        <field name="model">standard.common</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details">
                            <field name="detail_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="active"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_standard_common" model="ir.actions.act_window">
        <field name="name">Commons</field>
        <field name="res_model">standard.common</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
