<odoo>
    <record id="view_standard_process_tree" model="ir.ui.view">
        <field name="name">standard.process.tree</field>
        <field name="model">standard.process</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_standard_process_form" model="ir.ui.view">
        <field name="name">standard.process.form</field>
        <field name="model">standard.process</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Process Lines">
                            <field name="line_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="workcenter_id"/>
                                    <field name="duration"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_standard_process" model="ir.actions.act_window">
        <field name="name">Processes</field>
        <field name="res_model">standard.process</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
